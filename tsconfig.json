{
  "compilerOptions": {
    "sourceMap": true,
    "target": "es6",
    "outDir": "./build",
    "baseUrl": "./src",
    "alwaysStrict": true,
    "noImplicitAny": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "module": "es6",
    "resolveJsonModule":true
  },
  "include": [
    ".env",
    "src/**/*.ts",
 "seed.ts", "src/test/__tests__/demoController/demoTests.ts"  ],
  "exclude": [
    "node_modules"
  ]
}
